# Copy to .env and fill values before running commands.

# Nebius project + network
NEBIUS_PROJECT_ID=project-xxxxxxxxxxxxxxxx
# Optional: leave empty to auto-pick first subnet
NEBIUS_SUBNET_ID=

# Object storage — leave empty to auto-generate workshop-llm-<suffix> (unique per project, avoids collisions).
BUCKET_NAME=
BUCKET_MOUNT_PATH=/workspace/data

# Fine-tuning job
TRAIN_JOB_NAME=workshop-qwen-finetune
TRAIN_IMAGE=docker.io/axolotlai/axolotl:main-20260309-py3.11-cu128-2.9.1
TRAIN_PLATFORM=gpu-l40s-a
TRAIN_PRESET=1gpu-8vcpu-32gb
TRAIN_DISK_SIZE=450Gi
TRAIN_CONFIG_OBJECT=config.yaml
TRAIN_DATA_OBJECT=faq_train.jsonl
TRAIN_OUTPUT_PREFIX=output

# Endpoint
ENDPOINT_NAME=workshop-qwen-endpoint-v2
ENDPOINT_IMAGE=vllm/vllm-openai:v0.18.0-cu130
ENDPOINT_PLATFORM=gpu-l40s-a
ENDPOINT_PRESET=1gpu-8vcpu-32gb
ENDPOINT_PORT=8000
ENDPOINT_MODEL=Qwen/Qwen2.5-0.5B
ENDPOINT_LORA_NAME=qwen-support
# Fill after training completes (example: run-20260417-114332)
ENDPOINT_RUN_ID=
ENDPOINT_CHECKPOINT=checkpoint-50

# CPU VM for OpenClaw
CPU_VM_NAME=openclaw-cpu-vm-1
CPU_DISK_NAME=openclaw-cpu-disk-1
CPU_PLATFORM=cpu-d3
CPU_PRESET=4vcpu-16gb
CPU_DISK_GB=60
CPU_IMAGE_FAMILY=ubuntu24.04-driverless
CPU_VM_USER=user

# OpenClaw
OPENCLAW_MODEL=nebius/qwen-support
OPENCLAW_BIN=/home/user/.npm-global/bin/openclaw
OPENCLAW_SESSION_FILE=/home/user/.openclaw/agents/main/sessions/sessions.json
TRIAGE_TIMEOUT_SEC=20

# Telegram escalation
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
